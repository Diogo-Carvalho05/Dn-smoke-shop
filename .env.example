# Supabase (pegar em https://supabase.com/dashboard -> Project Settings -> API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=cole_aqui_sua_service_role_key   # NUNCA exponha no front, NUNCA commitar a real

# JWT (gere uma string aleatoria longa, ex: python -c "import secrets;print(secrets.token_hex(32))")
JWT_SECRET=troque_isto_por_uma_string_aleatoria_longa

# Admin (sera criado no primeiro deploy via SQL seed)
ADMIN_EMAIL=admin@dnsmokeshop.com
# A senha vai ser definida via hash no seed.sql

# WhatsApp da loja (formato internacional sem + e sem espacos, ex: 5511999999999)
LOJA_WHATSAPP=5511999999999
LOJA_NOME=Dn Smoke Shop
