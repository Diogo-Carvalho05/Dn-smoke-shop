{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/", "destination": "/index.html" },
    { "source": "/admin", "destination": "/admin/login.html" }
  ],
  "functions": {
    "api/**/*.py": { "runtime": "@vercel/python@4.3.0" }
  }
}
